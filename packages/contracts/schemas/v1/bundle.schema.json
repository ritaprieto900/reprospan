{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reprospan.dev/schemas/v1/bundle.schema.json",
  "title": "Reprospan Replay Bundle v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "bundle_id", "created_at", "capture_policy", "events"],
  "properties": {
    "schema_version": { "const": "reprospan.bundle.v1" },
    "bundle_id": { "type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]{0,127}$" },
    "created_at": { "type": "string", "format": "date-time" },
    "capture_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "redacted"],
      "properties": {
        "mode": { "const": "metadata_only" },
        "redacted": { "const": true }
      }
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "event.schema.json" }
    },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "event.schema.json#/$defs/artifactRef" },
      "uniqueItems": true
    }
  }
}
